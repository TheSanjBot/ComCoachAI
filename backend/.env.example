APP_NAME=CommCoach AI API
API_V1_PREFIX=/api/v1
ENVIRONMENT=development
DEBUG=true
SQL_ECHO=false
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=sqlite+aiosqlite:///./commcoach.db
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
UPLOADS_DIR=uploads
REPORTS_DIR=reports
MAX_UPLOAD_SIZE_MB=150
TRANSCRIPTION_MODEL_SIZE=small
TRANSCRIPTION_DEVICE=cpu
TRANSCRIPTION_COMPUTE_TYPE=int8
TRANSCRIPTION_BATCH_SIZE=4
AUDIO_SAMPLE_RATE=16000
VIDEO_ANALYSIS_SAMPLE_INTERVAL_SECONDS=1.0
INTERVIEW_LLM_TEMPERATURE=0.1
INTERVIEW_LLM_TIMEOUT_SECONDS=120
GRAMMAR_LLM_TIMEOUT_SECONDS=60
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-120b
CHROMA_PERSIST_DIRECTORY=chroma
CHROMA_COLLECTION=commcoach-memory
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
